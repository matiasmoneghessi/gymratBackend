// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Semana {
  id               Int               @id @default(autoincrement())
  numero           Int
  tipo_esfuerzo    String
  nombre           String
  dias             Dia[]
  ejercicioSemanas EjercicioSemana[]
  rutinaId         Int
  rutina           Rutina            @relation(fields: [rutinaId], references: [id], onDelete: Cascade)

  @@unique([rutinaId, numero])
  @@map("semanas")
}

model Dia {
  id          Int        @id @default(autoincrement())
  numero      Int
  nombre      String
  movilidad   String?    @db.Text
  activacion  String?    @db.Text
  semanaId    Int
  semana      Semana     @relation(fields: [semanaId], references: [id], onDelete: Cascade)
  ejercicios  Ejercicio[]

  @@unique([semanaId, numero])
  @@map("dias")
}

model Ejercicio {
  id              Int               @id @default(autoincrement())
  nombre          String
  codigo          String?
  video           String?           @db.Text
  diaId           Int
  dia             Dia               @relation(fields: [diaId], references: [id], onDelete: Cascade)
  ejercicioSemanas EjercicioSemana[]

  @@map("ejercicios")
}

model EjercicioSemana {
  id          Int       @id @default(autoincrement())
  ejercicioId Int
  semanaId    Int
  kg          Float?
  reps        Int
  series      Int
  ejercicio   Ejercicio @relation(fields: [ejercicioId], references: [id], onDelete: Cascade)
  semana      Semana    @relation(fields: [semanaId], references: [id], onDelete: Cascade)

  @@unique([ejercicioId, semanaId])
  @@map("ejercicio_semanas")
}

model Usuario {
  id_usuario      Int      @id @default(autoincrement()) @map("id_usuario")
  usuario         String   @unique
  password        String?
  nombre          String
  nivel           Int
  email           String   @unique
  telefono        String?
  supabaseUserId  String?  @unique @map("supabase_user_id")

  rutinas    Rutina[]

  @@map("usuarios")
}

model Rutina {
  id        Int      @id @default(autoincrement())
  nombre    String
  usuarioId Int

  usuario      Usuario      @relation(fields: [usuarioId], references: [id_usuario], onDelete: Cascade)
  semanas      Semana[]
  shareTokens  ShareToken[]

  @@map("rutinas")
}

model ShareToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @default(cuid())
  rutinaId  Int
  rutina    Rutina   @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("share_tokens")
}
